<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= invoice ? 'Edit' : 'Add' %> Invoice - RemindPro</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/nav') %>

  <div class="page-content">
    <div class="container">

      <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>

      <div class="page-header">
        <h1><%= invoice ? 'Edit Invoice' : 'New Invoice' %></h1>
        <a href="/invoices" class="btn btn-outline btn-sm">&larr; Back</a>
      </div>

      <div class="form-card">
        <form method="POST" action="<%= invoice ? '/invoices/' + invoice.id + '/edit' : '/invoices/add' %>">
          <div class="form-group">
            <label for="client_id">Client *</label>
            <select id="client_id" name="client_id" required>
              <option value="">Select a client</option>
              <% clients.forEach(function(c) { %>
              <option value="<%= c.id %>" <%= invoice && invoice.ClientID === c.id ? 'selected' : '' %>><%= c.Name %></option>
              <% }); %>
            </select>
            <% if (clients.length === 0) { %>
            <span class="text-muted">No clients yet. <a href="/clients/add">Add a client first</a>.</span>
            <% } %>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="amount">Amount ($) *</label>
              <input type="number" id="amount" name="amount" step="0.01" min="0" value="<%= invoice ? invoice.Amount : '' %>" required>
            </div>
            <div class="form-group">
              <label for="due_date">Due Date *</label>
              <input type="date" id="due_date" name="due_date" value="<%= invoice ? invoice.DueDate : '' %>" required>
            </div>
          </div>
          <% if (invoice) { %>
          <div class="form-group">
            <label for="status">Status</label>
            <select id="status" name="status">
              <option value="pending" <%= invoice.Status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="paid" <%= invoice.Status === 'paid' ? 'selected' : '' %>>Paid</option>
            </select>
          </div>
          <% } %>
          <div class="form-group">
            <label for="notes">Notes (optional)</label>
            <input type="text" id="notes" name="notes" value="<%= invoice ? invoice.Notes : '' %>" placeholder="e.g. Roof repair - Johnson property">
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= invoice ? 'Save Changes' : 'Create Invoice' %></button>
            <a href="/invoices" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>

    </div>
  </div>
</body>
</html>
